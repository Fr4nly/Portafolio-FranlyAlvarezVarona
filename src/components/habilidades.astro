---

---

<!-- Habilidades Section -->
    <section id="habilidades" class="py-16 mb-56">
      <div class="container mx-auto px-4 max-w-6xl">
        <!-- Título de la sección -->
        <div class="text-center mb-12">
          <h2 id="skillsTittle" class="section-title text-white text-4xl font-bold mb-10 relative text-center pb-4">
            Habilidades
          </h2>
        </div>

        <!-- Contenedor de las 3 tarjetas principales -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

          <!-- Tarjeta 1: Frontend Stack -->
          <div
            class="bg-slate-900/70 backdrop-blur-sm border border-slate-900 rounded-2xl p-6 shadow-lg hover:border-cyan-800 transition-all duration-300">
            <div class="mb-6">
              <h3 class="text-2xl font-bold text-white mb-4 flex items-center gap-3">
                
                <!-- SVG Frontend -->
                <svg width="24" height="24"> 
                  <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-monitor-dot" />
                </svg>
                Frontend
              </h3>
            </div>

            <!-- Cuadrícula responsiva para tecnologías Frontend -->
            <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-2 sm:gap-2 md:gap-4">
              <!-- HTML -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-orange-600 transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  
                  <!-- SVG HTML -->
                <svg width="full" height="full"> 
                  <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-html" />
                </svg>

                </div>
                <span class="text-white font-medium text-xs sm:text-sm text-center">HTML</span>
              </div>

              <!-- CSS -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-blue-700 transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  
                  <!-- SVG CSS -->
                <svg width="full" height="full"> 
                  <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-css" />
                </svg>

                </div>
                <span class="text-white font-medium text-xs sm:text-sm text-center">CSS</span>
              </div>

              <!-- JavaScript -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-yellow-300 transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  
                  <!-- SVG JavaScript -->
                <svg width="full" height="full"> 
                  <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-javascript" />
                </svg>

                </div>
                <span class="text-white font-medium text-xs sm:text-sm text-center">JavaScript</span>
              </div>

              <!-- Tailwind -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-sky-400 transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  

                   <!-- SVG Tailwind -->
                <svg width="full" height="full"> 
                  <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-tailwind" />
                </svg>

                </div>
                <span class="text-white font-medium text-xs sm:text-sm text-center">Tailwind</span>
              </div>

              <!-- Bootstrap -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-violet-600 transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  
                  <!-- SVG Bootstrap -->
                <svg width="full" height="full"> 
                  <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-bootstrap" />
                </svg>

                </div>
                <span class="text-white font-medium text-xs sm:text-sm text-center">Bootstrap</span>
              </div>

              <!-- Astro -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-white transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                    
                  <!-- SVG Astro -->
                <svg width="full" height="full"> 
                  <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-astro" />
                </svg>

                </div>
                <span class="text-white font-medium text-xs sm:text-sm text-center">Astro</span>
              </div>


            </div>
          </div>

          <!-- Tarjeta 2: Backend Stack -->
          <div
            class="bg-slate-900/70 backdrop-blur-sm border border-slate-900 rounded-2xl p-6 shadow-lg hover:border-cyan-800 transition-all duration-300">
            <div class="mb-6">
              <h3 class="text-2xl font-bold text-white mb-4 flex items-center gap-3">
                
                <!-- SVG Backend -->
                <svg width="24" height="24"> 
                  <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-server" />
                </svg>
                
                Backend
              </h3>
            </div>
            <!-- Cuadrícula responsiva para tecnologías Backend -->
            <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-2 sm:gap-2 md:gap-4">
              <!-- PHP -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-fuchsia-500 transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  
                  <!-- SVG PHP -->
                <svg width="128" height="128"> 
                  <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-php" />
                </svg>

                </div>
                <span class="text-white font-medium text-xs text-center">PHP</span>
              </div>

              <!-- MySQL -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-white transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  

                  <!-- SVG MySQL -->
                <svg width="full" height="full"> 
                  <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-mysql" />
                </svg>

                  
                </div>
                <span class="text-white font-medium text-xs text-center">MySQL</span>
              </div>

              <!-- Codeignater -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-orange-500 transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  
                   <!-- SVG Codeigniter -->
                <svg width="full" height="full"> 
                  <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-codeigniter" />
                </svg>

                </div>
                <span class="text-white font-medium text-xs text-center">Codeigniter</span>
              </div>
            </div>
          </div>

          <!-- Tarjeta 3: Tools -->
          <div
            class="bg-slate-900/70 backdrop-blur-sm border border-slate-900 rounded-2xl p-6 shadow-lg hover:border-cyan-800 transition-all duration-300">
            <div class="mb-6">
              <h3 class="text-2xl font-bold text-white mb-4 flex items-center gap-3">
                

                <!-- SVG Tools -->
                <svg width="24" height="24"> 
                  <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-wrench" />
                </svg>
                
                Tools
              </h3>
            </div>

            <!-- Cuadrícula 4x4 para herramientas -->
            <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-2 sm:gap-2 md:gap-4">
              <!-- Git -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-orange-500 transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  
                  <!-- Git -->
                  <svg width="full" height="full"> 
                    <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-git" />
                  </svg>
                
                
                </div>
                <span class="text-white font-medium text-xs text-center">Git</span>
              </div>

              <!-- GitHub -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-white transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">

                  <!-- GitHub -->
                  <svg width="full" height="full"> 
                    <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-github" />
                  </svg>




                </div>
                <span class="text-white font-medium text-xs text-center">GitHub</span>
              </div>





              <!-- VS Code -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-sky-500 transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  
                  <!-- VS Code -->
                  <svg width="full" height="full"> 
                    <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-vscode" />
                  </svg>
                  
                </div>
                <span class="text-white font-medium text-xs text-center">VS Code</span>
              </div>



              <!-- Figma -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-red-400 transition-all duration-300 hover:scale-105">

                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  <!-- SVG intacto -->
                  
                  <!-- Figma -->
                  <svg width="full" height="full"> 
                    <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-figma" />
                  </svg>
                  
                  
                </div>

                <span class="text-white font-medium text-xs text-center">
                  Figma
                </span>
              </div>





              <!-- Xampp -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-orange-400 transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  
                  <!-- Xampp -->
                  <svg width="full" height="full"> 
                    <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-xampp" />
                  </svg>
                  
                  
                </div>
                <span class="text-white font-medium text-xs text-center">Xampp</span>
              </div>

              <!-- Vite -->
              <div
                class="flex flex-col items-center p-3 bg-slate-800 rounded-lg hover:bg-slate-800/50 border border-transparent hover:border-purple-500 transition-all duration-300 hover:scale-105">
                <div class="w-10 h-10 flex items-center justify-center mb-2">
                  
                  <!-- Vite -->
                  <svg width="full" height="full"> 
                    <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-vite" />
                  </svg>
                  
                  

                </div>
                <span class="text-white font-medium text-xs text-center">Vite</span>
              </div>




            </div>





          </div>
        </div>

      </div>
      </div>
    </section>