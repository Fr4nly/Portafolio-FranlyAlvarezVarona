---

---

<!-- Sobre mi Section - Versión Horizontal Centrada -->
    <section id="sobre-mi" class="py-16 md:py-20 mb-56 ">
      <div class="container mx-auto px-4 max-w-6xl">
        <!-- Contenido en disposición horizontal -->
        <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">


          <!-- Foto a la derecha -->
          <div class="lg:w-2/5 flex justify-center lg:justify-end">
            <div class="relative">
              <div
                class="w-72 h-72 md:w-72 md:h-72 rounded-full overflow-hidden border-4 border-black shadow-2xl hover:scale-110 transition-all duration-500">
                <img src={`${import.meta.env.BASE_URL}Foto.webp`} alt="Foto de Franly Alvarez Varona" width="280" height="280" fetchpriority="high"/>
              </div>
            </div>
          </div>

          <!-- Contenido de texto centrado -->
          <div class="flex-1 text-center">
            <!-- Nombre con mejor legibilidad -->
            <h1 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">
              Franly Alvarez Varona
            </h1>

            

            <!-- Título profesional más destacado -->
            <div id="professional-title" class="text-cyan-400 font-semibold text-xl md:text-2xl mb-8 md:mb-10" >
              Desarrollador Web Frontend
            </div>

            <!-- Intro con mejor tipografía -->
            <div class="mb-10 md:mb-12 max-w-3xl mx-auto">
              <p id="intro-text" class="text-white text-lg md:text-xl leading-relaxed md:leading-relaxed font-light">
                Desarrollador web con <strong class="font-semibold text-cyan-400">más de 1 año de
                  experiencia</strong> en proyectos empresariales.
                Especializado en sistemas privados y soluciones escalables para empresas.
                Comprometido con el aprendizaje continuo y las mejores prácticas tecnológicas.
              </p>
            </div>

            <div class="flex flex-col sm:flex-row justify-center items-center gap-4">

              <!-- Botón idioma -->
              <button onclick="toggleLang()"
                class="inline-flex items-center gap-2 bg-black backdrop-blur-sm hover:bg-gray-800 text-white font-medium text-base py-3 px-3 rounded-full border border-gray-900/50 hover:border-gray-500 transition-all duration-200 hover:scale-105 active:scale-95 shadow-md hover:shadow-lg cursor-pointer">
                
                <!-- SVG Language -->
                <svg width="25" height="25"> 
                  <use href="#icon-language" />
                </svg>
              </button>              

              <!-- Botón de Ver CV -->
              <a href="assets/document/CV - Franly Alvarez Varona.pdf" download="CV_Franly_Alvarez_Varona.pdf"
                class="inline-flex items-center gap-2 bg-[rgba(20,20,20,0.85)] backdrop-blur-sm hover:bg-[rgba(40,40,40,0.9)] text-white font-medium text-base py-3 px-6 rounded-full border border-gray-900/50 hover:border-gray-500 transition-all duration-300 hover:scale-105 active:scale-95 shadow-md hover:shadow-lg">

                <!-- SVG CV -->
                <svg width="25" height="25"> 
                  <use href="#icon-document" />
                </svg>
                <span id="cv-button">Ver CV</span>
              </a>

              <!-- GitHub - Color negro/gris oficial (#24292E) -->
              <a href="https://github.com/Fr4nly" target="_blank"
                class="inline-flex items-center gap-2 bg-zinc-800 hover:bg-zinc-700 text-white font-medium text-base py-3 px-6 rounded-full border border-gray-700 hover:border-white transition-all duration-300 hover:scale-105 active:scale-95 shadow-md hover:shadow-lg">
                <!-- SVG GitHub -->
                <svg width="25" height="25"> 
                  <use href="#icon-github" />
                </svg>
                <span class="font-medium">GitHub</span>
              </a>

              <!-- Linkedin - Color negro/gris oficial (#24292E) -->
              <a href="https://www.linkedin.com/in/franly-alvarez-varona-2022193a2/" target="_blank"
                class="inline-flex items-center gap-2 bg-sky-700 hover:bg-sky-800 text-white font-medium text-base py-3 px-6 rounded-full border border-gray-700 hover:border-cyan-400 transition-all duration-300 hover:scale-105 active:scale-95 shadow-md hover:shadow-lg">
                <!-- SVG Linkedin -->
                <svg width="22" height="22"> 
                  <use href="#icon-linkedin" />
                </svg>
                <span class="font-medium">Linkedin</span>
              </a>


            </div>
          </div>
        </div>
      </div>
    </section>

    <script src={`${import.meta.env.BASE_URL}js/traduccion.js`} defer></script>