---

---

<!-- Sobre mi Section - Versión Horizontal Centrada -->
    <section id="sobre-mi" class="py-16 md:py-20 mb-56 ">
      <div class="container mx-auto px-4 max-w-6xl">
        <!-- Contenido en disposición horizontal -->
        <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">


          <!-- Foto a la derecha -->
          <div class="lg:w-2/5 flex justify-center lg:justify-end">
            <div class="relative">
              <div
                class="w-72 h-72 md:w-72 md:h-72 rounded-full overflow-hidden border-4 border-black shadow-2xl hover:scale-110 transition-all duration-500">
                <img 
  src={`${import.meta.env.BASE_URL}Foto.webp`} 
  alt="Foto de Franly Alvarez Varona"
/>
              </div>
            </div>
          </div>

          <!-- Contenido de texto centrado -->
          <div class="flex-1 text-center">
            <!-- Nombre con mejor legibilidad -->
            <h1 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">
              Franly Alvarez Varona
            </h1>

            <!-- Título profesional más destacado -->
            <div class="text-cyan-400 font-semibold text-xl md:text-2xl mb-8 md:mb-10">
              Desarrollador Web Frontend
            </div>

            <!-- Intro con mejor tipografía -->
            <div class="mb-10 md:mb-12 max-w-3xl mx-auto">
              <p class="text-white text-lg md:text-xl leading-relaxed md:leading-relaxed font-light">
                Desarrollador web con <strong class="font-semibold text-cyan-400">más de 1 año de
                  experiencia</strong> en proyectos empresariales.
                Especializado en sistemas privados y soluciones escalables para empresas.
                Comprometido con el aprendizaje continuo y las mejores prácticas tecnológicas.
              </p>
            </div>

            <div class="flex flex-col sm:flex-row justify-center items-center gap-4">

              <!-- Botón de Ver CV -->
              <a href="assets/document/CV - Franly Alvarez Varona.pdf" download="CV_Franly_Alvarez_Varona.pdf"
                class="inline-flex items-center gap-2 bg-[rgba(20,20,20,0.85)] backdrop-blur-sm hover:bg-[rgba(40,40,40,0.9)] text-white font-medium text-base py-3 px-6 rounded-full border border-gray-900/50 hover:border-light-gray/70 transition-all duration-300 hover:scale-105 active:scale-95 shadow-md hover:shadow-lg">

                <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path
                    d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z" />
                  <path d="M14 2v5a1 1 0 0 0 1 1h5" />
                  <path d="M10 9H8" />
                  <path d="M16 13H8" />
                  <path d="M16 17H8" />
                </svg>
                <span>Ver CV</span>
              </a>

              <!-- GitHub - Color negro/gris oficial (#24292E) -->
              <a href="https://github.com/Fr4nly" target="_blank"
                class="inline-flex items-center gap-2 bg-zinc-800 hover:bg-zinc-700 text-white font-medium text-base py-3 px-6 rounded-full border border-gray-700 hover:border-slate-600 transition-all duration-300 hover:scale-105 active:scale-95 shadow-md hover:shadow-lg">
                <svg width="25" height="25" viewBox="0 0 24 24" fill="currentColor">
                  <path fill-rule="evenodd" clip-rule="evenodd"
                    d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                </svg>
                <span class="font-medium">GitHub</span>
              </a>

              <!-- Linkedin - Color negro/gris oficial (#24292E) -->
              <a href="https://www.linkedin.com/in/franly-alvarez-varona-2022193a2/" target="_blank"
                class="inline-flex items-center gap-2 bg-sky-700 hover:bg-sky-800 text-white font-medium text-base py-3 px-6 rounded-full border border-gray-700 hover:border-slate-600 transition-all duration-300 hover:scale-105 active:scale-95 shadow-md hover:shadow-lg">
                <svg width="22" height="22" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1792 1792">
                  <path fill="white"
                    d="M477 625v991H147V625h330zm21-306q1 73-50.5 122T312 490h-2q-82 0-132-49t-50-122q0-74 51.5-122.5T314 148t133 48.5T498 319zm1166 729v568h-329v-530q0-105-40.5-164.5T1168 862q-63 0-105.5 34.5T999 982q-11 30-11 81v553H659q2-399 2-647t-1-296l-1-48h329v144h-2q20-32 41-56t56.5-52 87-43.5T1285 602q171 0 275 113.5t104 332.5z" />
                </svg>
                <span class="font-medium">Linkedin</span>
              </a>


            </div>
          </div>
        </div>
      </div>
    </section>