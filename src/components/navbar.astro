---

---

<!-- Notch-style Navbar -->
  <header id="main-header" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 transition-all duration-500">
    <nav class="bg-gray-900/85 backdrop-blur-sm border border-white/10 rounded-4xl p-2 shadow-xl ring-1 ring-white/10">

      <ul class=" flex justify-center items-center gap-1 list-none p-0 m-0 h-11">
        <!-- Item 1: Sobre mi -->
        <li class="relative transition-all duration-200 active:scale-90">
          <a href="#sobre-mi" class="group flex items-center justify-center no-underline text-white/80 bg-white/5 rounded-[25px] p-2.5 min-w-11 h-11 relative overflow-hidden transition-all duration-400 border border-transparent hover:bg-white/15 hover:border-white/20 hover:text-white hover:px-5 hover:min-w-max hover:shadow-lg hover:ring-1 hover:ring-white/20">


            <!-- SVG Sobre mi -->
            <svg width="25" height="25"> 
              <use href="#icon-user" />
            </svg>

            <!-- Text -->
            <span id="aboutme"
              class="text-sm font-medium opacity-0 -translate-x-2.5 transition-all duration-400 whitespace-nowrap overflow-hidden max-w-0 group-hover:opacity-100 group-hover:translate-x-0 group-hover:max-w-25 group-hover:ml-2 relative z-10">
              Sobre mi
            </span>
          </a>
        </li>

        <!-- Item 2: Habilidades -->
        <li class="relative transition-all duration-200 active:scale-90">
          <a href="#habilidades" class="group flex items-center justify-center no-underline text-white/80 bg-white/5 rounded-[25px] p-2.5 min-w-11 h-11 relative overflow-hidden transition-all duration-400 border border-transparent hover:bg-white/15 hover:border-white/20 hover:text-white hover:px-5 hover:min-w-max hover:shadow-lg hover:ring-1 hover:ring-white/20
">


            <!-- SVG Habilidades -->
            <svg width="25" height="25"> 
              <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-brain" />
            </svg>

            <span id="skills"
              class="text-sm font-medium opacity-0 -translate-x-2.5 transition-all duration-400 whitespace-nowrap overflow-hidden max-w-0 group-hover:opacity-100 group-hover:translate-x-0 group-hover:max-w-25 group-hover:ml-2 relative z-10">
              Habilidades
            </span>
          </a>
        </li>

        <!-- Item 3: Proyectos -->
        <li class="relative transition-all duration-200 active:scale-90">
          <a href="#proyectos" class="group flex items-center justify-center no-underline text-white/80 bg-white/5 rounded-[25px] p-2.5 min-w-11 h-11 relative overflow-hidden transition-all duration-400 border border-transparent hover:bg-white/15 hover:border-white/20 hover:text-white hover:px-5 hover:min-w-max hover:shadow-lg hover:ring-1 hover:ring-white/20
">

            <!-- SVG Proyectos -->
            <svg width="25" height="25"> 
              <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-monitor-cog" />
            </svg>

            <span id="projects"
              class="text-sm font-medium opacity-0 -translate-x-2.5 transition-all duration-400 whitespace-nowrap overflow-hidden max-w-0 group-hover:opacity-100 group-hover:translate-x-0 group-hover:max-w-25 group-hover:ml-2 relative z-10">
              Proyectos
            </span>
          </a>
        </li>

        <!-- Item 4: Contáctame -->
        <li class="relative transition-all duration-200 active:scale-90">
          <a href="#contactame" class="group flex items-center justify-center no-underline text-white/80 bg-white/5 rounded-[25px] p-2.5 min-w-11 h-11 relative overflow-hidden transition-all duration-400 border border-transparent hover:bg-white/15 hover:border-white/20 hover:text-white hover:px-5 hover:min-w-max hover:shadow-lg hover:ring-1 hover:ring-white/20">

            <!-- SVG Mail -->
            <svg width="25" height="25"> 
              <use href="/Portafolio-FranlyAlvarezVarona/icons.svg#icon-mail" />
            </svg>

            <span id="contactme"
              class="text-sm font-medium opacity-0 -translate-x-2.5 transition-all duration-400 whitespace-nowrap overflow-hidden max-w-0 group-hover:opacity-100 group-hover:translate-x-0 group-hover:max-w-25 group-hover:ml-2 relative z-10">
              Contáctame
            </span>
          </a>
        </li>
      </ul>
    </nav>
  </header>