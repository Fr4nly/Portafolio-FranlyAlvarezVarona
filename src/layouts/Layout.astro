---
import '../styles/global.css';
import Navbar from '../components/navbar.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Franly Alvarez Varona | Portafolio</title>

    <!-- Favicon -->
    <link rel="shortcut icon" href={`${import.meta.env.BASE_URL}favicon.ico`} type="image/x-icon" />

    <!-- Preconexión a Google Fonts (sin duplicados) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!--
      Fuente cargada de forma no bloqueante:
      - preload + onload evita que bloquee el FCP/LCP
      - el <noscript> cubre navegadores sin JS
    -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Expletus+Sans:ital,wght@0,400..700;1,400..700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Expletus+Sans:ital,wght@0,400..700;1,400..700&display=swap"
      />
    </noscript>

    <!-- EmailJS: único script que puede ir en <head> porque otros scripts dependen de él -->
    <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js" defer></script>
  </head>

  <body class="text-white pt-20 relative overflow-x-hidden scrollbar-hide">

    <!-- ============================================================
         FONDO ESPACIAL OPTIMIZADO PARA GPU
         Cambios vs versión anterior:
         - starfield-1 y starfield-2 envueltos en .starfield-wrapper
           para que translateX/Y tenga recorrido (el div hijo mide 200%)
         - box-shadow eliminado de las estrellas inline (causaba repaint)
         - Las estrellas conservan su glow visual vía el style estático,
           pero ya no se anima box-shadow
         ============================================================ -->
    <div class="space-bg fixed top-0 left-0 w-full h-full z-[-1] overflow-hidden bg-linear-to-b from-[#0a0a1a] via-[#0f1a3a] to-[#1a2b5a]">

      <!-- Gradiente adicional -->
      <div class="absolute inset-0 bg-linear-to-b from-indigo-950/30 via-purple-900/20 to-blue-950/40"></div>

      <!-- Nebulosas -->
      <div class="nebula nebula-1 absolute w-[80%] h-[60%] top-[10%] left-[10%] opacity-20 animate-nebula-glow" style="background: radial-gradient(ellipse at 30% 40%, rgba(80, 120, 255, 0.4) 0%, rgba(60, 100, 220, 0.25) 20%, transparent 60%); filter: blur(80px);"></div>
      <div class="nebula nebula-2 absolute w-[60%] h-[70%] top-[20%] left-[30%] opacity-15 animate-nebula-glow" style="animation-delay: -15s; background: radial-gradient(circle at 70% 60%, rgba(100, 150, 255, 0.3) 0%, rgba(70, 120, 230, 0.15) 15%, transparent 40%); filter: blur(100px);"></div>

      <!--
        STARFIELD 1 — deriva horizontal
        El wrapper oculta el exceso; el div hijo mide 200% de ancho
        para que translateX(-50%) recorra toda la pantalla sin saltos
      -->
      <div class="starfield-wrapper">
        <div class="starfield-1 animate-stars-drift-x" style="background-image: radial-gradient(2px 2px at 10% 15%, rgba(255,255,255,0.9), transparent), radial-gradient(2px 2px at 20% 30%, rgba(255,255,255,0.8), transparent), radial-gradient(2px 2px at 30% 45%, rgba(255,255,255,0.7), transparent), radial-gradient(2px 2px at 40% 60%, rgba(255,255,255,0.8), transparent), radial-gradient(2px 2px at 50% 25%, rgba(255,255,255,0.9), transparent), radial-gradient(2px 2px at 60% 40%, rgba(255,255,255,0.7), transparent), radial-gradient(2px 2px at 70% 55%, rgba(255,255,255,0.8), transparent), radial-gradient(2px 2px at 80% 70%, rgba(255,255,255,0.9), transparent), radial-gradient(2px 2px at 90% 35%, rgba(255,255,255,0.7), transparent), radial-gradient(2px 2px at 15% 75%, rgba(255,255,255,0.8), transparent), radial-gradient(2px 2px at 25% 20%, rgba(255,255,255,0.9), transparent), radial-gradient(2px 2px at 35% 65%, rgba(255,255,255,0.7), transparent), radial-gradient(2px 2px at 45% 30%, rgba(255,255,255,0.8), transparent), radial-gradient(2px 2px at 55% 75%, rgba(255,255,255,0.9), transparent), radial-gradient(2px 2px at 65% 20%, rgba(255,255,255,0.7), transparent), radial-gradient(2px 2px at 75% 55%, rgba(255,255,255,0.8), transparent), radial-gradient(2px 2px at 85% 80%, rgba(255,255,255,0.9), transparent), radial-gradient(2px 2px at 95% 45%, rgba(255,255,255,0.7), transparent); background-size: 50% 100%;"></div>
      </div>

      <!--
        STARFIELD 2 — deriva vertical
        El wrapper oculta el exceso; el div hijo mide 200% de alto
        para que translateY(-50%) recorra toda la pantalla sin saltos
      -->
      <div class="starfield-wrapper">
        <div class="starfield-2 animate-stars-drift-y" style="animation-delay: -60s; background-image: radial-gradient(1.5px 1.5px at 5% 10%, rgba(255,255,255,0.6), transparent), radial-gradient(1.5px 1.5px at 12% 22%, rgba(255,255,255,0.5), transparent), radial-gradient(1.5px 1.5px at 18% 34%, rgba(255,255,255,0.7), transparent), radial-gradient(1.5px 1.5px at 24% 46%, rgba(255,255,255,0.6), transparent), radial-gradient(1.5px 1.5px at 30% 58%, rgba(255,255,255,0.5), transparent), radial-gradient(1.5px 1.5px at 36% 70%, rgba(255,255,255,0.7), transparent), radial-gradient(1.5px 1.5px at 42% 82%, rgba(255,255,255,0.6), transparent), radial-gradient(1.5px 1.5px at 48% 14%, rgba(255,255,255,0.5), transparent), radial-gradient(1.5px 1.5px at 54% 26%, rgba(255,255,255,0.7), transparent), radial-gradient(1.5px 1.5px at 60% 38%, rgba(255,255,255,0.6), transparent), radial-gradient(1.5px 1.5px at 66% 50%, rgba(255,255,255,0.5), transparent), radial-gradient(1.5px 1.5px at 72% 62%, rgba(255,255,255,0.7), transparent), radial-gradient(1.5px 1.5px at 78% 74%, rgba(255,255,255,0.6), transparent), radial-gradient(1.5px 1.5px at 84% 86%, rgba(255,255,255,0.5), transparent), radial-gradient(1.5px 1.5px at 90% 18%, rgba(255,255,255,0.7), transparent), radial-gradient(1.5px 1.5px at 96% 30%, rgba(255,255,255,0.6), transparent); background-size: 100% 50%; opacity: 0.8;"></div>
      </div>

      <!-- CONSTELACIÓN OSA MAYOR -->
      <div class="constellation ursa-major">
        <div class="absolute w-2 h-2 top-[15%] left-[10%] animate-star-twinkle-slow rounded-full" style="background: rgba(255,255,255,0.95); box-shadow: 0 0 15px white, 0 0 30px rgba(100,150,255,0.5);"></div>
        <div class="absolute w-0.75 h-0.75 top-[15%] left-[13%] animate-star-twinkle-medium rounded-full" style="background: rgba(255,255,255,0.9); box-shadow: 0 0 10px white; animation-delay: -1s;"></div>
        <div class="absolute w-1 h-1 top-[20%] left-[13%] animate-star-twinkle-pulse rounded-full" style="background: rgba(255,255,255,1); box-shadow: 0 0 20px white, 0 0 40px rgba(100,180,255,0.6); animation-delay: -2s;"></div>
        <div class="absolute w-0.75 h-0.75 top-[23%] left-[17%] animate-star-twinkle-random rounded-full" style="background: rgba(255,255,255,0.85); box-shadow: 0 0 12px white; animation-delay: -0.5s;"></div>
        <div class="absolute w-2 h-2 top-[20%] left-[20%] animate-star-twinkle-fast rounded-full" style="background: rgba(255,255,255,0.9); box-shadow: 0 0 15px white; animation-delay: -1.5s;"></div>
        <div class="absolute w-0.75 h-0.75 top-[16%] left-[20%] animate-star-twinkle-medium rounded-full" style="background: rgba(255,255,255,0.8); box-shadow: 0 0 8px white; animation-delay: -3s;"></div>
        <div class="absolute w-1.25 h-1.25 top-[18%] left-[23%] animate-star-twinkle-slow rounded-full" style="background: rgba(255,255,255,1); box-shadow: 0 0 25px white, 0 0 50px rgba(120,170,255,0.7); animation-delay: -4s;"></div>
      </div>

      <!-- CONSTELACIÓN ORIÓN -->
      <div class="constellation orion">
        <div class="absolute w-1.5 h-1.5 top-[60%] left-[70%] animate-star-twinkle-pulse rounded-full" style="background: rgba(255,230,200,1); box-shadow: 0 0 30px white, 0 0 60px rgba(255,200,100,0.8);"></div>
        <div class="absolute w-1.25 h-1.25 top-[62%] left-[74%] animate-star-twinkle-random rounded-full" style="background: rgba(200,220,255,0.95); box-shadow: 0 0 20px rgba(180,210,255,0.9); animation-delay: -1s;"></div>
        <div class="absolute w-1 h-1 top-[65%] left-[74%] animate-star-twinkle-medium rounded-full" style="background: rgba(255,240,220,0.9); box-shadow: 0 0 15px rgba(255,230,200,0.8); animation-delay: -2s;"></div>
        <div class="absolute w-0.75 h-0.75 top-[67%] left-[78%] animate-star-twinkle-fast rounded-full" style="background: rgba(255,255,255,0.85); box-shadow: 0 0 10px white; animation-delay: -0.5s;"></div>
        <div class="absolute w-0.75 h-0.75 top-[58%] left-[72%] animate-star-twinkle-slow rounded-full" style="background: rgba(255,255,255,0.8); box-shadow: 0 0 12px white; animation-delay: -3s;"></div>
      </div>

      <!-- CONSTELACIÓN CASIOPEA -->
      <div class="constellation cassiopeia">
        <div class="absolute w-1 h-1 top-[25%] left-[80%] animate-star-twinkle-fast rounded-full" style="background: rgba(255,255,255,0.9); box-shadow: 0 0 18px white;"></div>
        <div class="absolute w-0.75 h-0.75 top-[28%] left-[83%] animate-star-twinkle-pulse rounded-full" style="background: rgba(255,255,255,0.85); box-shadow: 0 0 14px white; animation-delay: -1s;"></div>
        <div class="absolute w-1 h-1 top-[31%] left-[86%] animate-star-twinkle-medium rounded-full" style="background: rgba(220,230,255,0.95); box-shadow: 0 0 16px rgba(200,220,255,0.9); animation-delay: -2s;"></div>
        <div class="absolute w-0.75 h-0.75 top-[34%] left-[89%] animate-star-twinkle-random rounded-full" style="background: rgba(255,255,255,0.8); box-shadow: 0 0 12px white; animation-delay: -0.5s;"></div>
        <div class="absolute w-1.25 h-1.25 top-[29%] left-[85%] animate-star-twinkle-slow rounded-full" style="background: rgba(255,255,255,1); box-shadow: 0 0 22px white, 0 0 44px rgba(150,200,255,0.7); animation-delay: -3s;"></div>
      </div>

      <!-- CONSTELACIÓN LEO -->
      <div class="constellation leo">
        <div class="absolute w-1.25 h-1.25 top-[70%] left-[20%] animate-star-twinkle-medium rounded-full" style="background: rgba(255,240,200,0.95); box-shadow: 0 0 25px rgba(255,230,180,0.9);"></div>
        <div class="absolute w-1 h-1 top-[73%] left-[23%] animate-star-twinkle-fast rounded-full" style="background: rgba(255,255,255,0.9); box-shadow: 0 0 18px white; animation-delay: -1s;"></div>
        <div class="absolute w-0.75 h-0.75 top-[76%] left-[26%] animate-star-twinkle-pulse rounded-full" style="background: rgba(255,255,255,0.85); box-shadow: 0 0 14px white; animation-delay: -2s;"></div>
        <div class="absolute w-1 h-1 top-[72%] left-[28%] animate-star-twinkle-random rounded-full" style="background: rgba(220,230,255,0.9); box-shadow: 0 0 16px rgba(200,220,255,0.8); animation-delay: -0.5s;"></div>
      </div>

      <!-- ESTRELLAS INDIVIDUALES ADICIONALES -->
      <!-- Grupo rápido -->
      <div class="absolute w-1 h-1 top-[35%] left-[5%] animate-star-twinkle-fast rounded-full" style="background: rgba(255,255,255,0.9); box-shadow: 0 0 10px white; animation-delay: -0.3s;"></div>
      <div class="absolute w-1 h-1 top-[45%] left-[15%] animate-star-twinkle-fast rounded-full" style="background: rgba(255,255,255,0.8); box-shadow: 0 0 8px white; animation-delay: -1.2s;"></div>
      <div class="absolute w-1 h-1 top-[55%] left-[25%] animate-star-twinkle-fast rounded-full" style="background: rgba(255,255,255,0.9); box-shadow: 0 0 12px white; animation-delay: -2.1s;"></div>
      <!-- Grupo medio -->
      <div class="absolute w-0.5 h-0.5 top-[40%] left-[50%] animate-star-twinkle-medium rounded-full" style="background: rgba(255,255,255,0.9); box-shadow: 0 0 15px white; animation-delay: -0.7s;"></div>
      <div class="absolute w-0.5 h-0.5 top-[50%] left-[60%] animate-star-twinkle-medium rounded-full" style="background: rgba(255,255,255,0.8); box-shadow: 0 0 10px white; animation-delay: -2.5s;"></div>
      <!-- Grupo lento -->
      <div class="absolute w-0.75 h-0.75 top-[10%] left-[50%] animate-star-twinkle-slow rounded-full" style="background: rgba(255,255,255,1); box-shadow: 0 0 20px white;"></div>
      <div class="absolute w-0.75 h-0.75 top-[80%] left-[80%] animate-star-twinkle-slow rounded-full" style="animation-delay: -2s; background: rgba(255,255,255,0.9); box-shadow: 0 0 15px white;"></div>
      <!-- Estrellas azuladas -->
      <div class="absolute w-1 h-1 top-[65%] left-[5%] animate-star-twinkle-random rounded-full" style="background: rgba(200,220,255,0.9); box-shadow: 0 0 10px rgba(200,220,255,0.8); animation-delay: -0.4s;"></div>
      <div class="absolute w-1 h-1 top-[85%] left-[15%] animate-star-twinkle-random rounded-full" style="background: rgba(180,200,255,0.8); box-shadow: 0 0 8px rgba(180,200,255,0.7); animation-delay: -1.8s;"></div>
      <div class="absolute w-0.5 h-0.5 top-[75%] left-[90%] animate-star-twinkle-pulse rounded-full" style="background: rgba(160,180,255,0.9); box-shadow: 0 0 15px rgba(160,180,255,0.8); animation-delay: -1.2s;"></div>

      <!-- Brillo atmosférico -->
      <div class="space-glow absolute inset-0 opacity-15 animate-atmosphere-pulse" style="background: radial-gradient(ellipse at center, rgba(80,120,255,0.2) 0%, rgba(60,100,220,0.1) 30%, transparent 70%); filter: blur(60px);"></div>
    </div>

    <!-- Contenido principal -->
    <Navbar />
    <slot />

    <!--
      Scripts movidos al final de <body> para no bloquear el render.
      defer garantiza que se ejecutan tras parsear el HTML completo.
    -->
    <script src={`${import.meta.env.BASE_URL}js/app_Arbuz.js`} defer></script>
    <script src={`${import.meta.env.BASE_URL}js/email-js.js`} defer></script>
    <script src={`${import.meta.env.BASE_URL}js/navbar-scroll.js`} defer></script>
    <script src={`${import.meta.env.BASE_URL}js/proyectos.js`} defer></script>
  </body>
</html>

<style>
  html,
body {
  margin: 0;
  padding: 0;
  width: 100%;
  min-height: 100%;
  overflow-x: hidden;

  background:
    linear-gradient(
      to bottom,
      #0a0a1a,
      #0f1a3a,
      #1a2b5a
    );

  overscroll-behavior: none;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: -9999;

  background:
    linear-gradient(
      to bottom,
      #0a0a1a,
      #0f1a3a,
      #1a2b5a
    );
}

.space-bg {
  pointer-events: none;
}
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>